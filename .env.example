# 발급받은 인증키를 로컬 .env에만 입력하세요.
OPEN_FISCAL_API_KEY=

# 열린재정 데이터셋 상세화면의 실제 요청주소를 입력합니다.
OPEN_FISCAL_API_URL=

# 데이터셋에 따라 인증키 파라미터명이 다르면 수정합니다.
OPEN_FISCAL_API_KEY_PARAM=key

# 기본 응답형식과 페이지 파라미터
OPEN_FISCAL_RESPONSE_FORMAT=json
OPEN_FISCAL_PAGE_INDEX_PARAM=pIndex
OPEN_FISCAL_PAGE_SIZE_PARAM=pSize
OPEN_FISCAL_PAGE_SIZE=1000

# 요청 간격과 타임아웃
OPEN_FISCAL_REQUEST_INTERVAL_SECONDS=0.4
OPEN_FISCAL_TIMEOUT_SECONDS=30
